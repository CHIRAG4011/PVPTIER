{
  "version": 2,
  "installCommand": "cd ../.. && pnpm install && pnpm --filter @workspace/api-server run build",
  "buildCommand": "mkdir -p public",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.js" }
  ]
}
