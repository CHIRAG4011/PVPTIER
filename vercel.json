{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/api-server/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["artifacts/api-server/src/**", "lib/**"]
      }
    },
    {
      "src": "artifacts/pvp-leaderboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public",
        "buildCommand": "pnpm run build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/api/index.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
